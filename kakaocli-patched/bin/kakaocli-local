#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
BINARY_PATH="$REPO_ROOT/.build/release/kakaocli"

if [[ ! -x "$BINARY_PATH" ]]; then
  "$SCRIPT_DIR/install-kakaocli" --build-only
fi

exec "$BINARY_PATH" "$@"
