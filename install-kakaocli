#!/usr/bin/env bash
set -euo pipefail

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

if have_cmd kakaocli && have_cmd query-kakao; then
  printf 'External toolkit commands detected.\n'
  printf 'kakaocli: %s\n' "$(command -v kakaocli)"
  printf 'query-kakao: %s\n' "$(command -v query-kakao)"
  exit 0
fi

printf 'Missing external toolkit commands for this operator repo.\n' >&2
if ! have_cmd kakaocli; then
  printf -- '- kakaocli\n' >&2
fi
if ! have_cmd query-kakao; then
  printf -- '- query-kakao\n' >&2
fi

cat >&2 <<'EOF'

This repo no longer vendors the public kakaocli source tree.

Recommended first step for the core CLI:
  brew install silver-flight-group/tap/kakaocli

If query-kakao is still missing after that, install or expose the separate public
kakaocli toolkit so its bin directory is available on PATH.
EOF

exit 1
